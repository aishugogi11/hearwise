# Spotify (required for live listening)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback

# Public URL of your deployed app (production)
APP_URL=http://127.0.0.1:3000

# Server
NODE_ENV=development
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string
# Mac/Linux only: app reads system volume when server runs on your machine (not on cloud deploy)

# Optional: comma-separated extra CORS origins (browser extension, etc.)
# CORS_ORIGINS=

# Slack (optional — huddle detection + /hearwise commands)
SLACK_APP_ID=your_slack_app_id
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_LEVEL_TOKEN=xapp-your-app-level-token
# true in production on always-on host; false locally to avoid socket crashes
SLACK_SOCKET_MODE=false

# Featherless.ai (optional — Aura copy for Slack DMs and /hearwise)
FEATHERLESS_API_KEY=your_featherless_api_key
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct

# Database — SQLite default (set SQLITE_PATH on Render disk mount in production)
SQLITE_PATH=./data/hearwise.db
# Or PostgreSQL (requires SQL dialect migration — SQLite recommended for v1)
# DATABASE_URL=postgresql://user:password@host:5432/hearwise
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=hearwise
# DB_USER=postgres
# DB_PASSWORD=your_password

# Production only
# ENABLE_DEMO_TOOLS=false
# INTERNAL_API_KEY=long-random-key-for-admin-test-routes
