# Spotify Credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback

# Slack App Credentials
SLACK_APP_ID=your_slack_app_id
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_LEVEL_TOKEN=xapp-your-app-level-token
# Bot scopes: users:read, users.profile:read
# Bot events: user_huddle_changed

# Server
PORT=3000
SESSION_SECRET=change-this-to-a-random-string

# Database (optional — SQLite used by default)
DATABASE_URL=postgresql://user:password@localhost:5432/hearwise
