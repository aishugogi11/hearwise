{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start HearWise",
      "type": "shell",
      "command": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true; SLACK_SOCKET_MODE=false npm start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "hearwise",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "HearWise server running"
        }
      }
    },
    {
      "label": "Open HearWise in Browser",
      "type": "shell",
      "command": "open http://127.0.0.1:3000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": ["Start HearWise"],
      "dependsOrder": "sequence"
    }
  ]
}
